                start_btn = self.query_one(f"#start-{self.service_type.value}", Button)
                start_btn.label = self.strings["stop"] if active else self.strings["start"]

        def get_status_text(self) -> str:
            profile = self.profile
            parts = []
            installed = False
            if profile.path:
                if profile.requires_setup_done:
                    installed = check_setup_done(profile.path)
                else:
                    installed = os.path.isdir(profile.path)
            else:
                installed = os.path.exists("/usr/bin/ollama") or os.path.exists("/usr/local/bin/ollama")
            if not installed:
                parts.append(self.strings["not_installed"])
            else:
                if profile.unit_name:
