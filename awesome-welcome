# ============================================================================
# HELPER FUNCTIONS
# ============================================================================
def run_command(cmd: List[str], check: bool = False, capture: bool = True) -> tuple:
    """Run command and return (returncode, stdout, stderr)"""
    try:
        result = subprocess.run(cmd, check=check, capture_output=capture, text=True)
        return result.returncode, result.stdout.strip(), result.stderr.strip()
    except Exception as e:
        return 1, "", str(e)

def check_systemd_unit_active(unit: str) -> bool:
    code, out, _ = run_command(["systemctl", "is-active", unit])
    return code == 0

def check_systemd_unit_enabled(unit: str) -> bool:
    code, out, _ = run_command(["systemctl", "is-enabled", unit])
    return code == 0

def check_setup_done(path: str) -> bool:
    return os.path.isfile(os.path.join(path, ".setup_done"))

def is_display_available() -> bool:
    return bool(os.environ.get("DISPLAY"))

def open_tilix_with_command(cmd: str, title: str = "AI Services Manager"):
    """Run a command in a new Tilix window."""
    full_cmd = f'tilix -t "{title}" -e "bash -c \'{cmd}; echo; echo Press Enter to close; read\'"'
    subprocess.Popen(full_cmd, shell=True)

def get_downloads_dir() -> str:
    return GLib.get_user_special_dir(GLib.UserDirectory.DIRECTORY_DOWNLOAD) or os.path.expanduser("~/Downloads")

