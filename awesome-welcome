            for tab_id in ["kohya", "forge", "comfy", "ollama"]:
                try:
                    pane = self.query_one(f"#{tab_id}")
                    widget = pane.query_one(ServiceWidget)
                    widget.update_status()
                except:
                    pass

        def action_toggle_language(self):
            self.lang.toggle()
            # Update tab labels
            tabbed = self.query_one(TabbedContent)
            for i, st in enumerate([ServiceType.KOHYA, ServiceType.FORGE, ServiceType.COMFY, ServiceType.OLLAMA]):
                profile = SERVICE_REGISTRY[st]
                pane = tabbed.get_pane(tabbed.children[i])
                pane.label = self.lang.t(profile.display_name_key)
            docker_pane = tabbed.get_pane(tabbed.children[-1])
            docker_pane.label = self.lang.t("service_docker")
            self.refresh_all()

