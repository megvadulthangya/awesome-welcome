    # --- Event Handlers ---
    def on_install_clicked(self, btn, service_type):
        profile = SERVICE_REGISTRY[service_type]
        if profile.install_cmd:
            # Change directory to path if exists
            if profile.path:
                os.chdir(profile.path)
            subprocess.Popen(profile.install_cmd, shell=True)

    def on_toggle_enable(self, btn, service_type):
        profile = SERVICE_REGISTRY[service_type]
        if not profile.unit_name:
            return
        is_enabled = check_systemd_unit_enabled(profile.unit_name)
        if is_enabled:
            run_command(["sudo", "systemctl", "disable", "--now", profile.unit_name])
        else:
            run_command(["sudo", "systemctl", "enable", "--now", profile.unit_name])
        self.refresh_service_state(service_type)

    def on_toggle_start_stop(self, btn, service_type):
        profile = SERVICE_REGISTRY[service_type]
        if not profile.unit_name:
            return
        is_active = check_systemd_unit_active(profile.unit_name)
        if is_active:
            run_command(["sudo", "systemctl", "stop", profile.unit_name])
        else:
            run_command(["sudo", "systemctl", "start", profile.unit_name])
        self.refresh_service_state(service_type)

    def on_restart(self, btn, service_type):
        profile = SERVICE_REGISTRY[service_type]
        if profile.unit_name:
            run_command(["sudo", "systemctl", "restart", profile.unit_name])
            self.refresh_service_state(service_type)

