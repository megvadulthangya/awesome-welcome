            self.lbl_title.set_text(self.strings["welcome_title"])
            self.lbl_desc.set_text(self.strings["welcome_desc"])
            if not self.is_live:
                self.btn_services.set_label(self.strings["manage_services"])
                self.btn_services.set_tooltip_text(self.strings["manage_services_tooltip"])
                self.btn_pamac.set_label(self.strings["manage_software"])
                self.btn_wall.set_label(self.strings["install_wallpapers"])
