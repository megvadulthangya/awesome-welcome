            """Go back to previous screen; in TUI this is equivalent to exit."""
            self.exit()

        def on_key(self, event: events.Key):
            if event.key == "l":
                self.action_toggle_language()
            elif event.key == "q":
                self.exit()

    app = AIServicesManagerTUI()
    app.run()

